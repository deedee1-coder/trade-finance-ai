{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "extraction.schema.json",
  "title": "Field Extraction Schema",
  "type": "object",
  "required": [
    "case_id",
    "extracted_fields",
    "document_extractions"
  ],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "extracted_fields": {
      "type": "object",
      "required": [
        "applicant_name",
        "beneficiary_name",
        "invoice_amount",
        "currency",
        "shipment_date",
        "presentation_date",
        "lc_expiry_date",
        "goods_description",
        "country_of_origin"
      ],
      "properties": {
        "applicant_name": {
          "type": "string"
        },
        "beneficiary_name": {
          "type": "string"
        },
        "invoice_amount": {
          "type": "number"
        },
        "lc_amount": {
          "type": "number"
        },
        "currency": {
          "type": "string",
          "examples": ["USD", "EUR"]
        },
        "shipment_date": {
          "type": "string",
          "format": "date"
        },
        "presentation_date": {
          "type": "string",
          "format": "date"
        },
        "lc_expiry_date": {
          "type": "string",
          "format": "date"
        },
        "port_of_loading": {
          "type": "string"
        },
        "port_of_discharge": {
          "type": "string"
        },
        "goods_description": {
          "type": "string"
        },
        "country_of_origin": {
          "type": "string"
        },
        "vessel_name": {
          "type": "string"
        }
      }
    },
    "document_extractions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "document_id",
          "document_type",
          "fields"
        ],
        "properties": {
          "document_id": {
            "type": "string"
          },
          "document_type": {
            "type": "string"
          },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "field_name",
                "value",
                "confidence"
              ],
              "properties": {
                "field_name": {
                  "type": "string"
                },
                "value": {},
                "confidence": {
                  "type": "number",
                  "minimum": 0,
                  "maximum": 1
                }
              }
            }
          }
        }
      }
    }
  }
}