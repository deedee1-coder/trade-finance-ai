{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ExtractedDocs",
  "description": "Output of Agent B — structured fields extracted from every document.",
  "type": "object",
  "required": ["run_id", "documents"],
  "properties": {
    "run_id": { "type": "string" },
    "extraction_timestamp": { "type": "string", "format": "date-time" },
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["doc_type", "filename"],
        "properties": {
          "doc_type": { "type": "string" },
          "filename": { "type": "string" },
          "fields": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "value": {},
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "page": { "type": "integer" }
              }
            }
          },
          "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "low_confidence_fields": { "type": "array", "items": { "type": "string" } },
          "raw_text_snippet": { "type": "string" }
        }
      }
    }
  }
}
