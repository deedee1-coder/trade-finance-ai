{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ITFDS Shared Findings Schema",
  "type": "object",
  "required": ["case_id", "findings"],
  "properties": {
    "case_id": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_id",
          "agent_name",
          "check_id",
          "severity",
          "status",
          "document",
          "field",
          "expected_value",
          "actual_value",
          "explanation",
          "evidence",
          "policy_reference"
        ],
        "properties": {
          "finding_id": {
            "type": "string"
          },
          "agent_name": {
            "type": "string"
          },
          "check_id": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["minor", "major", "critical"]
          },
          "status": {
            "type": "string",
            "enum": ["failed", "warning", "resolved"]
          },
          "document": {
            "type": "string"
          },
          "field": {
            "type": "string"
          },
          "expected_value": {},
          "actual_value": {},
          "explanation": {
            "type": "string"
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "document",
                "field",
                "source",
                "page",
                "source_text",
                "confidence"
              ],
              "properties": {
                "document": {
                  "type": "string"
                },
                "field": {
                  "type": "string"
                },
                "source": {
                  "type": "string"
                },
                "page": {
                  "type": ["integer", "null"]
                },
                "source_text": {
                  "type": ["string", "null"]
                },
                "confidence": {
                  "type": ["number", "null"]
                }
              }
            }
          },
          "policy_reference": {
            "type": "string"
          }
        }
      }
    }
  }
}