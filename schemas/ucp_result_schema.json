{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UCPResult",
  "description": "Output of Agent C — UCP 600 rule-by-rule compliance results.",
  "type": "object",
  "required": ["run_id", "checks"],
  "properties": {
    "run_id": { "type": "string" },
    "checked_at": { "type": "string", "format": "date-time" },
    "icc_version": { "type": "string" },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule_id", "article", "status"],
        "properties": {
          "rule_id": { "type": "string" },
          "article": { "type": "string" },
          "description": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "WARNING", "N/A"] },
          "finding": { "type": "string" },
          "evidence": { "type": "string" },
          "severity": { "type": "string", "enum": ["major", "minor", "info"] }
        }
      }
    },
    "total_pass": { "type": "integer" },
    "total_fail": { "type": "integer" },
    "total_warning": { "type": "integer" }
  }
}
