{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MatchResult",
  "description": "Output of Agent D — cross-document field consistency checks.",
  "type": "object",
  "required": ["run_id", "comparisons"],
  "properties": {
    "run_id": { "type": "string" },
    "checked_at": { "type": "string", "format": "date-time" },
    "comparisons": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field_name", "doc_a", "doc_b", "match"],
        "properties": {
          "field_name": { "type": "string" },
          "doc_a": { "type": "string" },
          "doc_b": { "type": "string" },
          "value_a": {},
          "value_b": {},
          "match": { "type": "boolean" },
          "mismatch_detail": { "type": "string" },
          "severity": { "type": "string", "enum": ["major", "minor", "info"] }
        }
      }
    },
    "total_matches": { "type": "integer" },
    "total_mismatches": { "type": "integer" }
  }
}
